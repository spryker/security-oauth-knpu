{
    "name": "spryker/security-oauth-knpu",
    "type": "library",
    "description": "SecurityOauthKnpu module",
    "license": "proprietary",
    "require": {
        "knpuniversity/oauth2-client-bundle": "^2.0.0",
        "league/oauth2-client": "^2.0.0",
        "php": ">=8.3",
        "spryker-shop/customer-page-extension": "^1.9.0",
        "spryker/acl-merchant-portal-extension": "^1.0.0",
        "spryker/application-extension": "^1.1.0",
        "spryker/container": "^1.10.0",
        "spryker/customer": "^7.0.0",
        "spryker/customer-extension": "^1.7.0",
        "spryker/kernel": "^3.30.0",
        "spryker/log": "^3.0.0",
        "spryker/merchant-user": "^1.0.0",
        "spryker/security-extension": "^1.0.0",
        "spryker/security-gui-extension": "^1.6.0",
        "spryker/security-merchant-portal-gui-extension": "^1.5.0",
        "spryker/security-oauth-user-extension": "^1.1.0",
        "spryker/symfony": "^3.20.0",
        "spryker/transfer": "^3.27.0",
        "spryker/user": "^3.0.0"
    },
    "require-dev": {
        "spryker/application": "*",
        "spryker/code-sniffer": "*",
        "spryker/locale": "*",
        "spryker/merchant": "*",
        "spryker/propel": "*",
        "spryker/router": "*",
        "spryker/testify": "*"
    },
    "suggest": {
        "spryker/router": "Needed to register OAuth callback routes in Symfony's router so KnpU can generate correct redirect URLs."
    },
    "autoload": {
        "psr-4": {
            "Spryker\\": "src/Spryker/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SprykerTest\\": "tests/SprykerTest/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "scripts": {
        "cs-check": "phpcs -p -s --standard=vendor/spryker/code-sniffer/Spryker/ruleset.xml src/ tests/",
        "cs-fix": "phpcbf -p --standard=vendor/spryker/code-sniffer/Spryker/ruleset.xml src/ tests/"
    },
    "extra": {
        "branch-alias": {
            "dev-master": "1.0.x-dev"
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    }
}
