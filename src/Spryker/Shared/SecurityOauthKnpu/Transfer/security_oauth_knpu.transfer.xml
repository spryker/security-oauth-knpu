<?xml version="1.0"?>
<transfers xmlns="spryker:transfer-01"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="spryker:transfer-01 http://static.spryker.com/transfer-01.xsd">

    <transfer name="OauthKnpuUserIdentity" strict="true">
        <property name="idOauthKnpuUserIdentity" type="int"/>
        <property name="fkUser" type="int"/>
        <property name="provider" type="string"/>
        <property name="externalId" type="string"/>
        <property name="email" type="string"/>
        <property name="createdAt" type="string"/>
        <property name="updatedAt" type="string"/>
    </transfer>

    <transfer name="OauthKnpuCustomerIdentity" strict="true">
        <property name="idOauthKnpuCustomerIdentity" type="int"/>
        <property name="fkCustomer" type="int"/>
        <property name="provider" type="string"/>
        <property name="externalId" type="string"/>
        <property name="email" type="string"/>
        <property name="createdAt" type="string"/>
        <property name="updatedAt" type="string"/>
    </transfer>

    <transfer name="OauthKnpuAuthenticationRequest" strict="true">
        <property name="provider" type="string"/>
        <property name="code" type="string"/>
        <property name="state" type="string"/>
        <property name="redirectUri" type="string"/>
        <property name="scope" type="string"/>
    </transfer>

    <transfer name="OauthKnpuAuthenticationResponse" strict="true">
        <property name="isSuccessful" type="bool"/>
        <property name="resourceOwner" type="OauthKnpuResourceOwner"/>
        <property name="accessToken" type="string"/>
        <property name="refreshToken" type="string"/>
        <property name="error" type="string"/>
    </transfer>

    <transfer name="OauthKnpuResourceOwner" strict="true">
        <property name="id" type="string"/>
        <property name="email" type="string"/>
        <property name="firstName" type="string"/>
        <property name="lastName" type="string"/>
        <property name="username" type="string"/>
        <property name="rawData" type="array" singular="rawDataItem"/>
    </transfer>

    <transfer name="OauthKnpuMerchantUserIdentity" strict="true">
        <property name="idOauthKnpuMerchantUserIdentity" type="int"/>
        <property name="fkMerchantUser" type="int"/>
        <property name="provider" type="string"/>
        <property name="externalId" type="string"/>
        <property name="email" type="string"/>
        <property name="createdAt" type="string"/>
        <property name="updatedAt" type="string"/>
    </transfer>

    <transfer name="OauthKnpuIdentityCriteria" strict="true">
        <property name="provider" type="string"/>
        <property name="externalId" type="string"/>
        <property name="email" type="string"/>
        <property name="fkUser" type="int"/>
        <property name="fkCustomer" type="int"/>
        <property name="fkMerchantUser" type="int"/>
    </transfer>

    <transfer name="OauthKnpuProviderConfig" strict="true">
        <property name="clientName" type="string"/>
        <property name="statePrefix" type="string"/>
        <property name="linkText" type="string"/>
        <property name="scopes" type="string[]" singular="scope"/>
        <property name="options" type="array" singular="option"/>
    </transfer>

    <transfer name="ResourceOwnerRequest">
        <property name="state" type="string"/>
        <property name="code" type="string"/>
    </transfer>

    <transfer name="ResourceOwnerResponse">
        <property name="isSuccessful" type="bool"/>
        <property name="resourceOwner" type="ResourceOwner"/>
    </transfer>

    <transfer name="ResourceOwner">
        <property name="id" type="string"/>
        <property name="firstName" type="string"/>
        <property name="lastName" type="string"/>
        <property name="provider" type="string"/>
        <property name="email" type="string"/>
    </transfer>

    <transfer name="OauthAuthenticationLink">
        <property name="href" type="string"/>
    </transfer>

    <transfer name="Customer">
        <property name="idCustomer" type="int"/>
    </transfer>

    <transfer name="UserCriteria">
        <property name="userConditions" type="UserConditions" strict="true" description="Conditions for filtering users."/>
    </transfer>

    <transfer name="UserConditions" strict="true">
        <property name="userIds" type="int[]" singular="idUser" description="A collection of user identifiers."/>
    </transfer>

    <transfer name="UserCollection" strict="true">
        <property name="users" type="User[]" singular="user" description="A collection of users."/>
    </transfer>

    <transfer name="User">
        <property name="idUser" type="int"/>
    </transfer>

    <transfer name="MerchantUserCriteria">
    </transfer>

    <transfer name="MerchantUser">
    </transfer>

    <transfer name="AclEntityMetadataConfig">
    </transfer>

    <transfer name="AclEntityMetadata">
    </transfer>

    <transfer name="AclEntityRule">
    </transfer>

    <transfer name="UserCollectionResponse" strict="true">
        <property name="users" type="User[]" singular="user"/>
    </transfer>

</transfers>
